# ==============================================================
# THE REACTOR — Environment Variables
# lhex systems
# ==============================================================
# Copy this file to .env.local and fill in your values

# ==============================================================
# GROQ (Required for AI features — 100% FREE)
# Get your free key at: https://console.groq.com
# Free tier: generous limits, no credit card required
# Model used: llama-3.3-70b-versatile
# ==============================================================
GROQ_API_KEY=gsk_...

# ==============================================================
# ANTHROPIC (Optional — alternative to Groq)
# Get your key at: https://console.anthropic.com
# ==============================================================
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ==============================================================
# SUPABASE (Required for database)
# Get these from: https://app.supabase.com > Project Settings > API
# ==============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==============================================================
# EVOLUTION API (Required for WhatsApp integration)
# Install Evolution API: https://github.com/EvolutionAPI/evolution-api
# ==============================================================
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE_NAME=reactor-main

# Webhook URL that Evolution will call when messages arrive
# Set this in Evolution API dashboard
EVOLUTION_WEBHOOK_URL=https://your-domain.com/api/webhook/evolution

# ==============================================================
# APPLICATION (Optional customization)
# ==============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=The Reactor
NEXT_PUBLIC_COMPANY_NAME=lhex systems

# ==============================================================
# OPTIONAL INTEGRATIONS
# ==============================================================

# Redis (for production session/cache, optional)
# REDIS_URL=redis://localhost:6379

# Sentry (error monitoring, optional)
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# Analytics (optional)
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
